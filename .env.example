# ── App ──────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# ── OpenAI (LLM + vision + embeddings + audio) ──
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Embeddings & Vector Store ─────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/processed/chroma_db
FAISS_INDEX_PATH=./data/processed/faiss_index/index.bin

# ── RAG ──────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5
MIN_RELEVANCE_SCORE=0.35

# ── Socratic Engine ───────────────────────────
MAX_HINT_TURNS=2
MAX_SESSION_TURNS=30
SOCRATIC_STRICT_MODE=true

# ── Persistence ───────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/socratot.db

# ── Streamlit ─────────────────────────────────
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0

# ── Logging ───────────────────────────────────
LOG_DIR=./logs
LOG_ROTATION=10 MB

# ── Evaluation ────────────────────────────────
EVAL_DATASET_PATH=./evaluation/ground_truth.jsonl
